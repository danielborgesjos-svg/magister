model ObraArq {
  id                   String    @id @default(cuid())
  tenantId             String
  projetoId            String    @unique
  clienteId            String
  nome                 String
  endereco             String?
  metragem             Float?
  status               String    @default("nao_iniciada")
  percentualFisico     Int       @default(0)
  percentualFinanceiro Int       @default(0)
  dataInicio           DateTime?
  dataInicioReal       DateTime?
  prazoEstimado        DateTime?
  prazoRevisto         DateTime?
  diasAtraso           Int       @default(0)
  orcamentoPrevisto    Float     @default(0)
  valorComprometido    Float     @default(0)
  valorRealizado       Float     @default(0)
  etapaAtual           String?
  responsavelId        String?
  observacoes          String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  tenant     Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  projeto    ProjetoArq           @relation(fields: [projetoId], references: [id], onDelete: Cascade)
  atividades AtividadeObra[]
  diarios    DiarioObra[]
  visitas    VisitaTecnicaArq[]
  naoConfs   NaoConformidadeArq[]
  relatorios RelatorioObra[]

  @@index([tenantId])
  @@index([tenantId, clienteId])
  @@index([tenantId, status])
}

